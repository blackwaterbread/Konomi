{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["bun-types"],
    "paths": {
      "@core/*": ["../core/*"]
    }
  },
  "include": [
    "./**/*",
    "../core/**/*",
    "../../generated/prisma/**/*",
    "../../generated/prisma-server/**/*"
  ],
  "exclude": ["node_modules"]
}
