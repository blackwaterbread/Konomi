{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "baseUrl": "../..",
    "paths": {
      "@/*": ["src/web/src/*"],
      "@preload/*": ["src/app/preload/*"]
    }
  },
  "include": [
    "./**/*",
    "../app/preload/index.d.ts"
  ]
}
