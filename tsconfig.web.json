{
  "extends": "./node_modules/@electron-toolkit/tsconfig/tsconfig.json",
  "include": [
    "src/web/src/**/*",
    "src/app/renderer/src/**/*",
    "src/app/preload/index.d.ts",
    "tests/frontend/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "paths": {
      "@/*": ["./src/web/src/*"],
      "@preload/*": ["./src/app/preload/*"]
    }
  }
}
