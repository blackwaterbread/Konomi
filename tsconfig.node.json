{
  "extends": "./node_modules/@electron-toolkit/tsconfig/tsconfig.json",
  "include": ["electron.vite.config.*", "src/main/**/*", "src/preload/**/*", "src/renderer/src/types/**/*", "src/generated/prisma/**/*", "src/tests/**/*"],
  "compilerOptions": {
    "composite": true,
    "types": ["node", "electron-vite/node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/src/*"]
    }
  }
}
