{
  "extends": "./node_modules/@electron-toolkit/tsconfig/tsconfig.json",
  "include": [
    "electron.vite.config.*",
    "src/app/main/**/*",
    "src/app/preload/**/*",
    "src/web/src/types/**/*",
    "src/generated/prisma/**/*",
    "tests/backend/**/*",
    "src/core/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "types": ["node", "electron-vite/node"],
    "paths": {
      "@/*": ["./src/web/src/*"],
      "@core/*": ["./src/core/*"]
    }
  }
}
