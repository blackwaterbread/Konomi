{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "../out/web",
    "rootDir": "..",
    "paths": {
      "@core/*": ["../konomi-core/*"]
    }
  },
  "include": ["./**/*", "../konomi-core/**/*"],
  "exclude": ["node_modules"]
}
