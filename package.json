{
  "name": "konomi",
  "workspaces": ["src/core", "src/app", "src/web", "src/server"],
  "version": "0.14.0",
  "packageManager": "bun@1.2.20",
  "description": "AI image gallery with metadata parsing, search, and generation support",
  "main": "./out/main/index.js",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "react-devtools": "react-devtools",
    "react-devtools:start": "react-devtools",
    "dev:react-devtools": "cross-env KONOMI_REACT_DEVTOOLS=1 electron-vite dev -c src/app/electron.vite.config.ts",
    "dev:react-devtools:all": "concurrently -k -n devtools,app \"bun run react-devtools:start\" \"bun run dev:react-devtools\"",
    "typecheck:node": "tsc --noEmit -p src/app/tsconfig.json --composite false",
    "typecheck:web": "tsc --noEmit -p src/web/tsconfig.json --composite false",
    "typecheck": "bun run typecheck:node && bun run typecheck:web",
    "test:backend": "node ./scripts/run-electron-node.mjs ./node_modules/vitest/vitest.mjs run --config vitest.backend.config.ts",
    "test:backend:watch": "node ./scripts/run-electron-node.mjs ./node_modules/vitest/vitest.mjs --config vitest.backend.config.ts",
    "test:server": "vitest run --config vitest.server.config.ts",
    "test:server:watch": "vitest --config vitest.server.config.ts",
    "test:frontend": "vitest run --config vitest.frontend.config.ts",
    "test:frontend:watch": "vitest --config vitest.frontend.config.ts",
    "start": "electron-vite preview -c src/app/electron.vite.config.ts",
    "dev": "electron-vite dev -c src/app/electron.vite.config.ts",
    "dev:server": "bun --watch src/server/index.ts",
    "dev:web": "vite --config src/web/vite.config.ts",
    "dev:web:all": "concurrently -k -n server,web \"bun --watch src/server/index.ts\" \"vite --config src/web/vite.config.ts\"",
    "build": "bun run typecheck && electron-vite build -c src/app/electron.vite.config.ts",
    "build:web": "vite build --config src/web/vite.config.ts",
    "verify:prompts-db": "node ./scripts/run-electron-node.mjs ./scripts/verify-prompts-db.mjs",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "bun run build && bun run verify:prompts-db && electron-builder --dir --config src/app/electron-builder.yml",
    "build:win": "bun run build && bun run verify:prompts-db && electron-builder --win --config src/app/electron-builder.yml",
    "build:mac": "electron-vite build -c src/app/electron.vite.config.ts && bun run verify:prompts-db && electron-builder --mac --config src/app/electron-builder.yml",
    "build:linux": "electron-vite build -c src/app/electron.vite.config.ts && bun run verify:prompts-db && electron-builder --linux --config src/app/electron-builder.yml",
    "db:prepare-dir": "node ./scripts/ensure-database-dir.mjs",
    "db:generate": "bun run db:prepare-dir && cross-env DATABASE_URL=file:./database/konomi.db bunx --bun prisma generate",
    "db:migrate": "bun run db:prepare-dir && cross-env DATABASE_URL=file:./database/konomi.db bunx --bun prisma migrate dev",
    "db:init": "node ./scripts/reset-dev-user-data.mjs",
    "db:init:prisma": "bun run db:prepare-dir && cross-env DATABASE_URL=file:./database/konomi.db bunx --bun prisma migrate reset --force",
    "db:generate:server": "bunx --bun prisma generate --config prisma.server.config.ts",
    "db:push:server": "bunx --bun prisma db push --config prisma.server.config.ts",
    "db:migrate:server": "bunx --bun prisma migrate dev --config prisma.server.config.ts",
    "db:prompts": "node ./scripts/run-electron-node.mjs ./scripts/build-prompts-db.mjs",
    "prebuild:native": "node scripts/build-native.mjs",
    "docker:build": "docker build -t konomi:latest .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@fastify/static": "^9.1.1",
    "@konomi/app": "workspace:*",
    "@konomi/core": "workspace:*",
    "@konomi/server": "workspace:*",
    "@konomi/web": "workspace:*",
    "@prisma/adapter-mariadb": "^7.7.0",
    "mariadb": "^3.5.2"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "2.2.16",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tooltip": "1.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fflate": "^0.8.2",
    "i18next": "^25.8.18",
    "jsdom": "^29.0.1",
    "lucide-react": "^0.564.0",
    "node-addon-api": "^8.6.0",
    "novelai-sdk-unofficial": "^1.1.4",
    "prettier": "^3.7.4",
    "prisma": "^7.4.2",
    "react": "^19.2.4",
    "react-devtools": "^7.0.1",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "sonner": "^1.7.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "1.3.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.0"
  }
}
