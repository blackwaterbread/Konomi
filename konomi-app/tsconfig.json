{
  "extends": "../node_modules/@electron-toolkit/tsconfig/tsconfig.json",
  "include": [
    "electron.vite.config.*",
    "main/**/*",
    "preload/**/*",
    "../konomi-web/src/types/**/*",
    "../generated/prisma/**/*",
    "../konomi-core/**/*",
    "../tests/backend/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "types": ["node", "electron-vite/node"],
    "paths": {
      "@/*": ["../konomi-web/src/*"],
      "@core/*": ["../konomi-core/*"]
    }
  }
}
